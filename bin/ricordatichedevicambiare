#!/usr/bin/env bash
#
# ricordatichedevicambiare — ti ricorda di cambiare la password prima che scada.
#
# Punto di ingresso: carica i moduli, la configurazione e smista i comandi.

set -uo pipefail

# --- Codici di uscita ---------------------------------------------------------
readonly EX_OK=0
readonly EX_ERR=1
readonly EX_MISSING_DEP=2
readonly EX_NO_EXPIRY_INFO=3
readonly EX_USAGE=64

# --- Individuazione della directory dei moduli --------------------------------
# Funziona sia eseguendo dal repository (./bin + ./lib) sia da installato
# (~/.local/bin + ~/.local/lib/ricordatichedevicambiare).
rcdc_resolve_dirs() {
    local src="${BASH_SOURCE[0]}"
    while [[ -L "$src" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    local bindir
    bindir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"

    # Base del repository (per share/guide.md in esecuzione locale).
    RCDC_BASE_DIR="$(cd -P "$bindir/.." >/dev/null 2>&1 && pwd)"

    # Verifichiamo la presenza effettiva di un modulo noto (config.sh),
    # non solo della cartella, perché ~/.local/lib può esistere comunque.
    if [[ -n "${RCDC_LIB_DIR:-}" && -f "$RCDC_LIB_DIR/config.sh" ]]; then
        :
    elif [[ -f "$bindir/../lib/config.sh" ]]; then
        RCDC_LIB_DIR="$(cd -P "$bindir/../lib" >/dev/null 2>&1 && pwd)"
    elif [[ -f "$HOME/.local/lib/ricordatichedevicambiare/config.sh" ]]; then
        RCDC_LIB_DIR="$HOME/.local/lib/ricordatichedevicambiare"
    else
        echo "rcdc: impossibile trovare la directory dei moduli (lib)" >&2
        exit "$EX_ERR"
    fi
}

rcdc_resolve_dirs

# shellcheck source=lib/config.sh
source "$RCDC_LIB_DIR/config.sh"
# shellcheck source=lib/levels.sh
source "$RCDC_LIB_DIR/levels.sh"
# shellcheck source=lib/password.sh
source "$RCDC_LIB_DIR/password.sh"
# shellcheck source=lib/state.sh
source "$RCDC_LIB_DIR/state.sh"
# shellcheck source=lib/notify.sh
source "$RCDC_LIB_DIR/notify.sh"
# shellcheck source=lib/guide.sh
source "$RCDC_LIB_DIR/guide.sh"
# shellcheck source=lib/help.sh
source "$RCDC_LIB_DIR/help.sh"

# --- Comando: controllo reale -------------------------------------------------
rcdc_run_check() {
    rcdc_load_config

    local expiry
    if ! expiry="$(rcdc_password_expiry_epoch)"; then
        echo "rcdc: impossibile determinare la scadenza della password" >&2
        return "$EX_NO_EXPIRY_INFO"
    fi

    # Password senza scadenza: non fare nulla.
    if [[ "$expiry" == "never" ]]; then
        rcdc_state_reset
        return "$EX_OK"
    fi

    local days level
    days="$(rcdc_days_until "$expiry")"
    level="$(rcdc_level "$days" "$WARNING_DAYS")"

    # Fuori dal periodo di preavviso.
    if (( level == 0 )); then
        rcdc_state_reset
        return "$EX_OK"
    fi

    # Per il messaggio mostriamo almeno 0 giorni (mai negativo).
    local shown_days="$days"
    (( shown_days < 0 )) && shown_days=0

    if rcdc_should_notify "$level"; then
        rcdc_notify "$level" "$shown_days" || return "$EX_MISSING_DEP"
        rcdc_state_set "$level"
    fi

    return "$EX_OK"
}

# --- Comando: test ------------------------------------------------------------
rcdc_run_test() {
    rcdc_load_config

    if ! command -v notify-send >/dev/null 2>&1; then
        echo "rcdc: notify-send non disponibile (dipendenza obbligatoria)" >&2
        return "$EX_MISSING_DEP"
    fi

    local target="${1:-all}"

    if [[ "$target" == "all" ]]; then
        local l
        for l in 1 2 3 4 5; do
            local d; d="$(rcdc_days_for_level "$l" "$WARNING_DAYS")"
            echo "rcdc: test livello $l (simulazione: $d giorni)"
            rcdc_notify "$l" "$d"
            sleep 2
        done
        return "$EX_OK"
    fi

    if ! [[ "$target" =~ ^[1-5]$ ]]; then
        echo "rcdc: livello di test non valido: '$target' (usa 1-5)" >&2
        return "$EX_USAGE"
    fi

    local d; d="$(rcdc_days_for_level "$target" "$WARNING_DAYS")"
    echo "rcdc: test livello $target (simulazione: $d giorni)"
    rcdc_notify "$target" "$d"
    return "$EX_OK"
}

# --- Comando: guida -----------------------------------------------------------
rcdc_run_guide() {
    rcdc_load_config
    rcdc_show_guide
}

# --- Dispatcher ---------------------------------------------------------------
main() {
    case "${1:-}" in
        ""|--check)
            rcdc_run_check
            ;;
        --test)
            rcdc_run_test "${2:-all}"
            ;;
        --guide)
            rcdc_run_guide
            ;;
        -h|--help)
            rcdc_help
            ;;
        -V|--version)
            rcdc_version
            ;;
        *)
            echo "rcdc: opzione sconosciuta: '$1'" >&2
            echo "Usa 'ricordatichedevicambiare --help' per l'elenco delle opzioni." >&2
            return "$EX_USAGE"
            ;;
    esac
}

main "$@"
exit $?
